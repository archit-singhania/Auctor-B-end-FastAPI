# ── Auctor FastAPI — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── OpenAI (used for CV skill extraction) ─────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# ── GitHub (used for repo verification) ───────────────────────────────────────
# Create a fine-grained PAT at https://github.com/settings/tokens
# Needs: public_repo read access (no write needed)
GITHUB_TOKEN=ghp_...your-token-here...

# ── Server ────────────────────────────────────────────────────────────────────
# Origins allowed for CORS — Flutter web dev and Android emulator
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8000

# ── Score weights (must sum to 1.0) ───────────────────────────────────────────
WEIGHT_GITHUB=0.25
WEIGHT_LEETCODE=0.15
WEIGHT_BADGES=0.30
WEIGHT_PROJECTS=0.15
WEIGHT_EXPERIENCE=0.15

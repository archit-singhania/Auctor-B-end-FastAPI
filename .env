# ── Auctor FastAPI — Environment Variables ────────────────────────────────────
# This file is for LOCAL development only.
# For Railway production, set these as environment variables in the Railway dashboard.

# ── PostgreSQL (local dev fallback) ───────────────────────────────────────────
# On Railway, set DATABASE_URL instead — it takes priority over these fields.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=demo_db
DB_USER=postgres
DB_PASSWORD=2526
DB_SCHEMA=auctor

# ── OpenAI (CV skill extraction) ──────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── GitHub (repo verification) ────────────────────────────────────────────────
# ⚠️  REQUIRED for GitHub verification to work.
# Create a classic or fine-grained PAT at https://github.com/settings/tokens
# Minimum scopes needed: public_repo (read-only is fine)
# Without this, GitHub returns 401 Unauthorized.
GITHUB_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your Vercel frontend URL here so the browser doesn't block API calls.
# Example: ALLOWED_ORIGINS=https://auctor-f-end-flutter.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=https://auctor-f-end-flutter.vercel.app,http://localhost:3000,http://localhost:8000,http://10.0.2.2:8000

# ── Score weights (must sum to 1.0) ───────────────────────────────────────────
WEIGHT_GITHUB=0.25
WEIGHT_LEETCODE=0.15
WEIGHT_BADGES=0.30
WEIGHT_PROJECTS=0.15
WEIGHT_EXPERIENCE=0.15
